import { expect, test } from '@playwright/test';

test.describe('__Feature__', () => {
  test('__describes the user-visible journey__', async ({ page }) => {
    await page.goto('/');

    // 1. Arrange: assert the starting state the user lands on.
    // 2. Act: drive the UI the way a user would (getByRole, click, fill).
    await page.getByRole('button', { name: '__action__' }).click();

    // 3. Assert: the user-visible outcome.
    await expect(page.getByRole('status')).toHaveText('__expected outcome__');
  });
});
