# This template needs no runtime secrets. The variables below are only used by
# CI / the E2E + StyleProof tooling, and are documented here for reference.
# Copy to `.env` only if you need to override a default locally.

# Point Playwright at a server you manage yourself instead of letting it boot
# the Vite dev server (the StyleProof workflow sets this to the built preview).
# E2E_BASE_URL=http://localhost:3000
