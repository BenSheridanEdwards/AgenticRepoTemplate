#!/usr/bin/env sh
set -e

# Pre-push = the BEHAVIOUR safety net. Nothing leaves the machine until the
# unit suite and the end-to-end behaviour map are green. This is the local
# mirror of what CI re-runs on the server.

echo "› unit + component tests with coverage (Jest + React Testing Library)"
pnpm test:coverage

echo "› production build smoke (Vite)"
pnpm build

echo "› end-to-end behaviour map (Playwright)"
pnpm e2e

echo "› restore or publish the exact StyleProof map"
head_sha="$(git rev-parse HEAD)"
if ! pnpm exec styleproof-map --restore --sha "$head_sha" --dir current --base-dir .styleproof/maps --spec e2e/styleproof.spec.ts; then
  pnpm exec styleproof-map --spec e2e/styleproof.spec.ts --sha "$head_sha" --upload
fi
pnpm exec styleproof-diff || true
