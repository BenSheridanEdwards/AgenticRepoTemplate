{
  "name": "agentic-project-template",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "A reference scaffold for agentic engineering: the files, gates, and context that make AI agents produce consistent, enterprise-quality code.",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 3000",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "fallow:audit": "bash scripts/fallow-audit.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "e2e": "playwright test e2e/app.spec.ts e2e/accessibility.spec.ts",
    "e2e:install": "playwright install --with-deps chromium",
    "size": "size-limit",
    "lhci": "lhci autorun",
    "secret-scan": "bash scripts/secret-scan.sh",
    "license:check": "node scripts/license-check.mjs",
    "verify": "pnpm typecheck && pnpm check && pnpm fallow:audit && pnpm test:coverage && pnpm build && pnpm size",
    "setup:agents": "bash scripts/setup-agentic-toolkit.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@commitlint/types": "^19.5.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.49.1",
    "@size-limit/file": "^12.1.0",
    "@swc/core": "^1.10.7",
    "@swc/jest": "^0.2.37",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.14",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "fallow": "^2.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "size-limit": "^12.1.0",
    "styleproof": "^3.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
